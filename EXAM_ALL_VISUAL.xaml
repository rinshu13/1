<Window x:Class="Magazin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Magazin" Height="680" Width="1080"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Times New Roman"
        Background="White">
    <Window.Resources>
        <SolidColorBrush x:Key="MainBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondBrush" Color="#7FFF00"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#00FA9A"/>
        <SolidColorBrush x:Key="DiscountBrush" Color="#2E8B57"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#C8D0C0"/>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="14 8"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource MainBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <Border x:Name="LoginPanel" Grid.RowSpan="4" Background="White" Panel.ZIndex="20">
            <Border Width="420"
                    Padding="26"
                    BorderBrush="{StaticResource SecondBrush}"
                    BorderThickness="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Авторизация"
                               FontSize="26"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 24"/>

                    <StackPanel Grid.Row="1" Margin="0 0 0 10">
                        <TextBlock Text="Логин" FontSize="16"/>
                        <TextBox x:Name="TbLogin" Height="38"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0 0 0 18">
                        <TextBlock Text="Пароль" FontSize="16"/>
                        <PasswordBox x:Name="PbPassword" Height="38"/>
                    </StackPanel>

                    <Button Grid.Row="3" Content="Войти" Height="42" Click="BtnLogin_Click"/>
                </Grid>
            </Border>
        </Border>

        <Border Grid.Row="0" Background="{StaticResource SecondBrush}" Padding="14">
            <DockPanel LastChildFill="True">
                <Image Source="logo.png"
                       Width="58"
                       Height="58"
                       Stretch="Uniform"
                       DockPanel.Dock="Left"
                       Margin="0 0 14 0"/>
                <TextBlock Text="Magazin"
                           FontSize="28"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnAdd" Content="Добавить" Click="BtnAdd_Click"/>
                    <Button x:Name="BtnEdit" Content="Изменить" Click="BtnEdit_Click"/>
                    <Button x:Name="BtnDelete" Content="Удалить" Click="BtnDelete_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="14 12 14 8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TbSearch"
                     Grid.Column="0"
                     TextChanged="TbSearch_TextChanged"
                     ToolTip="Поиск"/>
            <ComboBox x:Name="CbFilter"
                      Grid.Column="1"
                      SelectionChanged="CbFilter_SelectionChanged"
                      DisplayMemberPath="Title"
                      SelectedValuePath="ID"/>
            <ComboBox x:Name="CbSort"
                      Grid.Column="2"
                      SelectionChanged="CbSort_SelectionChanged">
                <ComboBoxItem Content="Без сортировки" Tag=""/>
                <ComboBoxItem Content="Название по возрастанию" Tag="Title ASC"/>
                <ComboBoxItem Content="Название по убыванию" Tag="Title DESC"/>
                <ComboBoxItem Content="Цена по возрастанию" Tag="Cost ASC"/>
                <ComboBoxItem Content="Цена по убыванию" Tag="Cost DESC"/>
            </ComboBox>
            <Button Grid.Column="3" Content="Обновить" Click="BtnRefresh_Click"/>
        </Grid>

        <ListBox x:Name="DgItems"
                 Grid.Row="2"
                 Margin="14 0"
                 BorderBrush="{StaticResource BorderBrush}"
                 MouseDoubleClick="DgItems_MouseDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="0 0 0 8"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="White"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HighDiscount}" Value="True">
                            <Setter Property="Background" Value="#2E8B57"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NoStock}" Value="True">
                            <Setter Property="Background" Value="#87CEFA"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black"
                            BorderThickness="2"
                            Background="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Background}">
                        <Grid MinHeight="150">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="145"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    BorderBrush="Black"
                                    BorderThickness="2"
                                    Margin="8"
                                    Background="White">
                                <Grid>
                                    <Image Source="{Binding MainImagePath}"
                                           Stretch="Uniform"
                                           Margin="8"/>
                                    <TextBlock Text="Фото"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="18"
                                               FontWeight="Bold"/>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="12 10">
                                <TextBlock FontSize="18" FontWeight="Bold">
                                    <Run Text="{Binding CategoryID, StringFormat=Категория {0}}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding Title}"/>
                                </TextBlock>

                                <TextBlock FontSize="16" TextWrapping="Wrap">
                                    <Run Text="Описание товара: "/>
                                    <Run Text="{Binding Description}"/>
                                </TextBlock>

                                <TextBlock FontSize="16">
                                    <Run Text="Артикул: "/>
                                    <Run Text="{Binding Article}"/>
                                </TextBlock>

                                <TextBlock FontSize="16">
                                    <Run Text="Поставщик: "/>
                                    <Run Text="не указан"/>
                                </TextBlock>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Цена: " FontSize="16"/>
                                    <TextBlock x:Name="OldCostText"
                                               Text="{Binding Cost}"
                                               FontSize="16"/>
                                    <TextBlock x:Name="NewCostText"
                                               Text="{Binding FinalCost, StringFormat=  {0}}"
                                               FontSize="16"
                                               Foreground="Black"
                                               Visibility="Collapsed"/>
                                </StackPanel>

                                <TextBlock FontSize="16">
                                    <Run Text="Единица измерения: "/>
                                    <Run Text="шт."/>
                                </TextBlock>

                                <TextBlock FontSize="16">
                                    <Run Text="Количество на складе: "/>
                                    <Run Text="{Binding Quantity}"/>
                                </TextBlock>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    BorderBrush="Black"
                                    BorderThickness="2"
                                    Margin="0 8 8 8"
                                    Background="White">
                                <TextBlock Text="{Binding DiscountPercentText}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding HasDiscount}" Value="True">
                            <Setter TargetName="OldCostText" Property="TextDecorations" Value="Strikethrough"/>
                            <Setter TargetName="OldCostText" Property="Foreground" Value="Red"/>
                            <Setter TargetName="NewCostText" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock x:Name="TbCount"
                   Grid.Row="3"
                   VerticalAlignment="Center"
                   Margin="18 0"
                   Foreground="Black"/>

        <Border x:Name="EditPanel"
                Grid.RowSpan="4"
                Background="#AAFFFFFF"
                Visibility="Collapsed"
                Panel.ZIndex="15">
            <Border Width="520"
                    Padding="22"
                    Background="White"
                    BorderBrush="{StaticResource SecondBrush}"
                    BorderThickness="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TbEditHeader"
                               Text="Запись"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 16"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Артикул" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox x:Name="TbEditArticle" Grid.Column="1"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Название" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox x:Name="TbEditTitle" Grid.Column="1"/>
                    </Grid>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Категория" VerticalAlignment="Center" FontSize="16"/>
                        <ComboBox x:Name="CbEditCategory"
                                  Grid.Column="1"
                                  DisplayMemberPath="Title"
                                  SelectedValuePath="ID"/>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Цена" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox x:Name="TbEditCost" Grid.Column="1"/>
                    </Grid>

                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Скидка" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox x:Name="TbEditDiscount" Grid.Column="1"/>
                    </Grid>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Количество" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox x:Name="TbEditQuantity" Grid.Column="1"/>
                    </Grid>

                    <Grid Grid.Row="7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Описание" VerticalAlignment="Top" Margin="0 10 0 0" FontSize="16"/>
                        <TextBox x:Name="TbEditDescription"
                                 Grid.Column="1"
                                 Height="80"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"/>
                    </Grid>

                    <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 14 0 0">
                        <Button Content="Сохранить" Click="BtnSaveEdit_Click"/>
                        <Button Content="Отмена" Background="{StaticResource SecondBrush}" Click="BtnCancelEdit_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
